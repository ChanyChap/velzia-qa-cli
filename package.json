{
  "name": "@chanychap/qa-cli",
  "version": "0.2.0",
  "description": "Centinela + Sastre — testing autónomo en la nube para apps Velzia",
  "type": "module",
  "bin": {
    "qa-cli": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ChanyChap/velzia-qa-cli.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --test dist/tests/*.test.js",
    "dev:centinela": "tsx src/cli.ts centinela",
    "dev:sastre": "tsx src/cli.ts sastre"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@browserbasehq/sdk": "^2.0.0",
    "@browserbasehq/stagehand": "^1.10.0",
    "lighthouse": "^12.0.0",
    "playwright": "^1.50.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": { "node": ">=20.0.0" }
}
